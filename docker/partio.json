{
    "Rest": {
        "Hostname": "*",
        "Port": 8400,
        "Ssl": false
    },
    "Database": {
        "Type": "Sqlite",
        "Filename": "/app/data/partio.db",
        "Hostname": null,
        "Port": 0,
        "DatabaseName": null,
        "Username": null,
        "Password": null,
        "Instance": null,
        "Schema": null,
        "RequireEncryption": false,
        "LogQueries": false
    },
    "Logging": {
        "SyslogServers": [],
        "ConsoleLogging": true,
        "EnableColors": false,
        "LogDirectory": "/app/logs/",
        "LogFilename": "partio.log",
        "FileLogging": true,
        "IncludeDateInFilename": true,
        "MinimumSeverity": 0
